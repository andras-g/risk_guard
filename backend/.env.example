# Risk Guard Backend — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit a .env file with real values.
# In production (GCP Cloud Run), all secrets are injected from GCP Secret Manager.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=riskguard
DB_USER=riskguard
DB_PASSWORD=

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 characters for HS256 signing
JWT_SECRET=

# ── Google OAuth2 SSO ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Microsoft OAuth2 SSO (Entra / Azure AD) ───────────────────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# ── Resend — Transactional Email ──────────────────────────────────────────────
RESEND_API_KEY=

# ── Application ───────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false

# ── GCP (Production only — injected automatically by Cloud Run) ──────────────
# SPRING_PROFILES_ACTIVE=prod
# INSTANCE_CONNECTION_NAME=PROJECT:REGION:INSTANCE   # Cloud SQL connection name
