# Exclude test sources and build artifacts from Docker build context
# This significantly reduces build context size and improves CI build speed.

src/test/
.gradle/
build/
# Exception: jOOQ generated sources must be present for compileJava.
# In CI, flywayMigrate + generateJooq run before 'docker build' to populate this.
!build/generated-sources/
compose.yaml
HELP.md
*.md

# IDE files
.idea/
.vscode/
*.iml

# OS files
.DS_Store
Thumbs.db
