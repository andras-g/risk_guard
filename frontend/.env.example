# Risk Guard Frontend — Environment Variables
# Copy this file to .env and fill in values for local development.
# NEVER commit a .env file with real values.
# In production, NUXT_PUBLIC_API_BASE is set as a Cloud Run environment variable.

# ── API Base URL ──────────────────────────────────────────────────────────────
# Points to the backend Cloud Run URL in production.
# Example staging: https://risk-guard-backend-staging-xxx.run.app/api/v1
# Example production: https://risk-guard-backend-production-xxx.run.app/api/v1
NUXT_PUBLIC_API_BASE=http://localhost:8080
