{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "lint": "eslint .",
    "check-i18n": "node scripts/i18n-check.js",
    "generate-types": "openapi-typescript ../backend/build/generated/openapi.json -o types/api.d.ts",
    "generate-zod": "openapi-zod-client ../backend/build/generated/openapi.json -o types/api.zod.ts",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "devDependencies": {
    "@intlify/eslint-plugin-vue-i18n": "^4.3.0",
    "@playwright/test": "^1.58.2",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vue/test-utils": "^2.4.6",
    "eslint": "^9.16.0",
    "eslint-plugin-vue": "^9.32.0",
    "eslint-plugin-vuejs-accessibility": "^2.5.0",
    "jsdom": "^28.1.0",
    "openapi-typescript": "^7.4.4",
    "openapi-zod-client": "^1.18.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vitest-axe": "^0.1.0"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@nuxtjs/i18n": "^10.2.3",
    "@pinia/nuxt": "^0.11.3",
    "@primevue/nuxt-module": "^4.5.4",
    "@primevue/themes": "^4.5.4",
    "@tailwindcss/vite": "^4.2.1",
    "jwt-decode": "^4.0.0",
    "nuxt": "^4.3.1",
    "pinia": "^3.0.4",
    "primeicons": "^7.0.0",
    "primevue": "^4.5.4",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.29",
    "vue-router": "^4.6.4",
    "zod": "^4.3.6"
  }
}
